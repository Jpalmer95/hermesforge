; Engine configuration file.
; HermesForge base template — Godot 4.7.1
; All curated modules ship pre-wired: Terrain3D + Gaea 2.0 enabled as plugins,
; Jolt available as the 3D physics backend.

config_version=5

[application]

config/name="HermesForge Base"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[editor_plugins]

enabled=PackedStringArray("terrain_3d", "gaea")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

renderer/rendering_method="forward_plus"

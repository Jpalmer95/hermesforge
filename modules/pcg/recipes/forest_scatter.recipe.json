{
  "id": "forest_scatter",
  "module": "pcg",
  "description": "Poisson-disc scatter mask for trees/props over a biome",
  "params": {
    "size": {
      "type": "int",
      "default": 256
    },
    "seed": {
      "type": "int",
      "default": 0
    },
    "density": {
      "type": "float",
      "default": 0.6,
      "min": 0.0,
      "max": 1.0
    },
    "min_spacing": {
      "type": "float",
      "default": 4.0
    },
    "biome": {
      "type": "enum",
      "values": [
        "pine",
        "jungle",
        "alpine"
      ],
      "default": "pine"
    }
  },
  "emits": {
    "nodes": [],
    "signals": []
  }
}
